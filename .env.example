# Environment Variables Template
# ============================================================
# Is file ko copy karke .env banao (local development ke liye)
# Production mein ye variables platform dashboard mein set karo.
# KABHI BHI .env file ko git mein push mat karo!
# ============================================================

# ─── REQUIRED ────────────────────────────────────────────────

# WordPress WPGraphQL plugin ka full URL
# WPGraphQL plugin install karo: https://wordpress.org/plugins/wp-graphql/
# Format: https://YOUR-DOMAIN.com/graphql
GRAPHQL_ENDPOINT=https://YOUR-WORDPRESS-SITE.com/graphql

# WordPress site ka base URL (bina trailing slash ke)
# Example: https://myblog.com
WP_BASE_URL=https://YOUR-WORDPRESS-SITE.com

# ─── OPTIONAL ────────────────────────────────────────────────

# Fallback image URL (agar post mein featured image nahi hai)
# Agar empty rakho to OG image tag generate nahi hoga
FALLBACK_IMAGE=
